# Serve index.html by default
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block web access to hidden files (.git, etc.) except .well-known
    RewriteRule (^|/)\.(?!well-known)[^/]+ - [F,L]

    # Redirect index / index.html to the clean directory root
    RewriteCond %{THE_REQUEST} \s/+(.*?)index(?:\.html)?[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Redirect *.html requests to extensionless clean URLs
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Internally serve extensionless URLs from the matching .html file
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
    RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# Protect admin config & data from direct web access
<FilesMatch "^(config\.php|emails\.json|otp-debug\.log)$">
    Require all denied
</FilesMatch>
